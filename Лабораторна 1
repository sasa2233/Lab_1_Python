# --- Выполнение Задания ---

# 1. Создать массив (используем numpy array)
a = np.array([7.0, 9.0, 11.0, 3.0, 8.0])

# 2. Вывести его на печать
print("Массив a:", a)

# 3. Вывести его размерность (shape), сумму и среднее значение элементов
print("Размерность (shape):", a.shape)
print("Сумма элементов:", np.sum(a))
print("Среднее значение элементов:", np.mean(a))

# 4. Вывести минимальный элемент и его индекс в массиве
print("Минимальный элемент:", np.min(a))
print("Индекс минимального элемента:", np.argmin(a))
